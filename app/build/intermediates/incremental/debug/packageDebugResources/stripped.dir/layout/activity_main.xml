<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <!-- Video preview surface -->
        <androidx.cardview.widget.CardView
            android:id="@+id/previewCard"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitleText">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <VideoView
                    android:id="@+id/previewVideo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/noVideoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/no_video_selected"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/pickButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="@string/pick_video"
            android:textColor="@color/text_primary"
            app:cornerRadius="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/previewCard"
            app:strokeColor="@color/accent" />

        <!-- Playback speed control -->
        <TextView
            android:id="@+id/speedLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/speed_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pickButton" />

        <TextView
            android:id="@+id/speedValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speed_default_display"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            app:layout_constraintBaseline_toBaselineOf="@id/speedLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <SeekBar
            android:id="@+id/speedSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="35"
            android:progress="15"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/speedLabel" />

        <!-- Crop / scaling mode control -->
        <TextView
            android:id="@+id/cropLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/crop_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/speedSeekBar" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/cropToggleGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cropLabel"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/cropFillButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/crop_fill"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:strokeColor="@color/accent" />

            <Button
                android:id="@+id/cropFitButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/crop_fit"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:strokeColor="@color/accent" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <Button
            android:id="@+id/setLockButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/accent"
            android:enabled="false"
            android:text="@string/set_lock"
            android:textColor="@color/text_primary"
            app:cornerRadius="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cropToggleGroup" />

        <Button
            android:id="@+id/setHomeButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/accent"
            android:enabled="false"
            android:text="@string/set_home"
            android:textColor="@color/text_primary"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/setLockButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
